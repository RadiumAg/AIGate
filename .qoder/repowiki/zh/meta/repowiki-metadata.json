a8","id":"67856d67-6bc4-4611-9990-a3905ff13bfe","gmt_create":"2026-03-13T21:02:11+08:00","gmt_modified":"2026-03-13T21:02:11+08:00"},{"catalog_id":"3149ae4f-993d-41df-951c-e31ed4541207","title":"Demo Data System","description":"demo-data-system","extend":"{}","progress_status":"completed","repo_id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8","id":"88e7f239-4725-4842-9d32-8ec95b223c69","gmt_create":"2026-03-13T22:08:52+08:00","gmt_modified":"2026-03-13T23:09:17+08:00"},{"catalog_id":"bf195338-be65-4e38-b3a0-d2a86498d001","title":"Nextjs Build Configuration","description":"nextjs-build-configuration","extend":"{}","progress_status":"completed","repo_id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8","id":"5a636b01-5d7b-49ca-845d-212aac5f8ea9","gmt_create":"2026-03-14T00:36:09+08:00","gmt_modified":"2026-03-14T00:36:09+08:00"},{"catalog_id":"013eaca4-1909-44d1-879a-5d21fc6f3b3b","title":"账单趋势图表组件","description":"billing-trend-chart","extend":"{}","progress_status":"completed","repo_id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8","id":"c62f9b83-abe0-4131-b02f-98a9275be1c7","gmt_create":"2026-03-15T22:56:16.180584+08:00","gmt_modified":"2026-03-15T22:56:16.184908+08:00"}],"wiki_overview":{"content":"\u003cblog\u003e\n\n# AIGate - AI 网关管理系统项目分析\n\n## 1. 项目介绍\n\n### 项目概述\nAIGate 是一个智能 AI 网关管理系统，专为多用户共享 AI 模型资源而设计。该项目提供了一个轻量级、可私有部署的解决方案，支持多种主流 AI 服务提供商，包括 OpenAI、Anthropic、Google、DeepSeek、Moonshot 等。\n\n### 核心目标\n- **统一 API 接口**：为所有支持的 AI 模型提供统一的 OpenAI 兼容接口\n- **用户级配额控制**：为每个终端用户设置独立的 Token 配额与调用频率限制\n- **安全代理服务**：使用用户自己的 API Key，确保安全性\n- **实时监控与统计**：提供完整的用量统计和成本可视化\n\n### 目标用户\n- SaaS 创业公司\n- AI 应用开发者\n- 教育平台\n- 内部工具开发团队\n\n## 2. 技术架构\n\n### 系统架构图\n\n```mermaid\ngraph TD\n    A[客户端应用] --\u003e B[Next.js 前端]\n    B --\u003e C[tRPC API 层]\n    C --\u003e D[AI Provider 层]\n    D --\u003e E[Drizzle ORM]\n    E --\u003e F[(PostgreSQL 数据库)]\n    \n    G[Dashboard 管理界面] --\u003e H[配额管理]\n    G --\u003e I[API Key 管理]\n    G --\u003e J[用户策略管理]\n    G --\u003e K[用量统计分析]\n    \n    L[Redis 缓存] --\u003e E\n    M[NextAuth.js] --\u003e N[用户认证系统]\n```\n\n### 核心组件关系\n\n```mermaid\nclassDiagram\n    class DashboardLayout {\n        +navigation: NavigationItem[]\n        +toggleTheme()\n        +validateUserById()\n    }\n    \n    class AIProvider {\n        +name: string\n        +models: string[]\n        +makeRequest()\n        +estimateTokens()\n    }\n    \n    class DatabaseLayer {\n        +apiKeyDb: ApiKeyRepository\n        +quotaPolicyDb: QuotaPolicyRepository\n        +usageRecordDb: UsageRecordRepository\n        +whitelistRuleDb: WhitelistRuleRepository\n    }\n    \n    class QuotaSystem {\n        +checkQuota()\n        +recordUsage()\n        +getUserQuotaPolicy()\n    }\n    \n    DashboardLayout --\u003e DatabaseLayer\n    AIProvider --\u003e QuotaSystem\n    DatabaseLayer --\u003e QuotaSystem\n```\n\n## 3. 关键实现\n\n### 主要入口点\n- **应用布局**：`src/app/layout.tsx` - 定义全局应用布局和主题配置\n- **仪表板布局**：`src/components/dashboard-layout.tsx` - 管理后台导航和侧边栏\n- **数据库配置**：`src/lib/database.ts` - 数据库连接和操作封装\n\n### 核心模块\n\n#### AI 供应商集成\n- **供应商抽象**：`src/lib/ai-providers.ts` - 定义统一的 AI 供应商接口\n- **OpenAI 集成**：支持流式和非流式请求处理\n- **Anthropic 集成**：Claude 模型的兼容处理\n- **Google Gemini 集成**：Gemini 模型的 API 适配\n\n#### 数据库模型\n- **Schema 定义**：`src/lib/schema.ts` - 使用 Drizzle ORM 定义数据库表结构\n- **配额策略**：支持按 Token 和请求次数的双重限制\n- **用户白名单**：灵活的用户权限控制机制\n\n#### API 层\n- **tRPC 路由器**：`src/server/api/root.ts` - 集中管理所有 API 端点\n- **AI 路由器**：`src/server/api/routers/ai.ts` - 处理 AI 请求的核心逻辑\n- **流式聊天**：`src/pages/api/ai/chat/stream.ts` - SSE 流式响应处理\n\n### 配置管理\n- **Next.js 配置**：`next.config.ts` - React Compiler 启用和输出配置\n- **Tailwind CSS**：`tailwind.config.js` - 自定义主题和暗色模式支持\n- **环境变量**：`.env` - 数据库连接和外部服务配置\n\n### 外部依赖\n- **框架层**：Next.js 16.1.6 + React 19.2.3\n- **数据库层**：Drizzle ORM + PostgreSQL\n- **缓存层**：Redis 4.6.10\n- **认证层**：NextAuth.js + Auth Core\n- **UI 组件**：Radix UI + Tailwind CSS\n\n### 集成点\n- **AI 服务集成**：OpenAI、Anthropic、Google Gemini、DeepSeek、Moonshot、Spark\n- **用户认证**：支持多种 OAuth 提供商\n- **用量统计**：ECharts 图表展示\n\n## 4. 关键特性\n\n### 功能架构图\n\n```mermaid\nstateDiagram-v2\n    [*] --\u003e 用户认证\n    用户认证 --\u003e 白名单验证\n    白名单验证 --\u003e API Key 验证\n    API Key 验证 --\u003e 配额检查\n    配额检查 --\u003e AI 请求处理\n    AI 请求处理 --\u003e 用量记录\n    用量记录 --\u003e [*]\n    \n    配额检查 --\u003e 拒绝: 配额不足\n    白名单验证 --\u003e 拒绝: 权限不足\n    API Key 验证 --\u003e 拒绝: Key 无效\n```\n\n### 实现亮点\n\n#### 多供应商支持\n- **统一接口**：所有 AI 供应商通过统一的接口进行调用\n- **流式处理**：支持 SSE 流式响应，提升用户体验\n- **Token 估算**：智能估算请求的 Token 消耗\n\n#### 智能配额管理\n- **双重限制**：同时支持 Token 数量和请求频率限制\n- **用户级控制**：为每个用户独立设置配额策略\n- **实时统计**：提供详细的用量统计和趋势分析\n\n#### 安全与审计\n- **白名单机制**：灵活的用户权限控制\n- **IP 地理位置**：记录用户请求的地理位置信息\n- **完整日志**：所有请求都有详细的操作记录\n\n### 特性实现\n\n#### Dashboard 管理界面\n- **仪表板统计**：实时显示系统使用情况\n- **配额管理**：可视化配额策略配置\n- **API Key 管理**：安全的密钥管理和轮换\n- **用户策略**：灵活的用户权限和配额分配\n\n#### 实时监控\n- **用量图表**：ECharts 图表展示 Token 消耗趋势\n- **地区分布**：地理热力图显示用户分布\n- **活动日志**：详细的用户操作记录\n\n## 5. 结论与建议\n\n### 项目优势\n1. **架构清晰**：采用分层架构，职责分离明确\n2. **扩展性强**：支持多种 AI 供应商，易于添加新服务\n3. **功能完整**：涵盖从认证到监控的完整功能链\n4. **性能优化**：使用 Redis 缓存和流式处理提升性能\n\n### 改进建议\n1. **微服务化**：考虑将不同功能模块拆分为独立的服务\n2. **容器化部署**：完善 Docker 配置，支持更灵活的部署方式\n3. **监控增强**：添加更详细的性能指标和告警机制\n4. **测试覆盖**：增加单元测试和集成测试覆盖率\n\n### 下一步发展\n1. **API 文档**：完善 RESTful API 文档\n2. **插件系统**：支持自定义配额策略和白名单规则\n3. **多租户支持**：为 SaaS 场景提供多租户架构\n4. **国际化**：支持多语言界面\n\nSources:\n- [package.json](package.json)\n- [next.config.ts](next.config.ts)\n- [src/app/layout.tsx](src/app/layout.tsx)\n- [src/components/dashboard-layout.tsx](src/components/dashboard-layout.tsx)\n- [src/lib/database.ts](src/lib/database.ts)\n- [src/server/api/root.ts](src/server/api/root.ts)\n- [src/server/api/routers/ai.ts](src/server/api/routers/ai.ts)\n- [src/lib/ai-providers.ts](src/lib/ai-providers.ts)\n- [src/lib/schema.ts](src/lib/schema.ts)\n- [src/pages/api/ai/chat/stream.ts](src/pages/api/ai/chat/stream.ts)\n- [tailwind.config.js](tailwind.config.js)\n- [readme/project-description.md](readme/project-description.md)\n\n\u003c/blog\u003e","gmt_create":"2026-02-28T22:39:12+08:00","gmt_modified":"2026-02-28T22:39:12+08:00","id":"bfefe936-0341-4307-830a-ecf2f659ae3d","repo_id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8"},"wiki_readme":{"content":"No readme file","gmt_create":"2026-02-28T20:18:12+08:00","gmt_modified":"2026-02-28T20:18:12+08:00","id":"6d77817c-efa8-48da-bd5b-a03a809d64f8","repo_id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8"},"wiki_repo":{"id":"f93f5bc1-3d8b-4ce7-a412-b2c8eef5eca8","name":"AIGate","progress_status":"completed","wiki_present_status":"COMPLETED","optimized_catalog":"\".\\n├── .next/dev/\\n│   ├── build/\\n│   │   ├── chunks/\\n│   │   ├── package.json\\n│   │   ├── postcss.js\\n│   │   ├── postcss.js.map\\n│   │   ├── webpack-loaders.js\\n│   │   └── webpack-loaders.js.map\\n│   ├── cache/\\n│   │   ├── turbopack/23c464985/\\n│   │   │   ├── 00000005.sst\\n│   │   │   ├── 00000006.sst\\n│   │   │   ├── 00000007.sst\\n│   │   │   ├── 00000008.sst\\n│   │   │   ├── 00000009.meta\\n│   │   │   ├── 00000011.meta\\n│   │   │   ├── 00000012.meta\\n│   │   │   ├── 00000013.meta\\n│   │   │   ├── 00000015.sst\\n│   │   │   ├── 00000016.sst\\n│   │   │   ├── 00000017.sst\\n│   │   │   ├── 00000018.sst\\n│   │   │   ├── 00000019.meta\\n│   │   │   ├── 00000020.meta\\n│   │   │   ├── 00000022.meta\\n│   │   │   ├── 00000023.meta\\n│   │   │   ├── 00000025.sst\\n│   │   │   ├── 00000026.sst\\n│   │   │   ├── 00000027.sst\\n│   │   │   ├── 00000028.sst\\n│   │   │   ├── 00000029.meta\\n│   │   │   ├── 00000030.meta\\n│   │   │   ├── 00000032.meta\\n│   │   │   ├── 00000033.meta\\n│   │   │   ├── 00000034.sst\\n│   │   │   ├── 00000036.sst\\n│   │   │   ├── 00000037.meta\\n│   │   │   ├── 00000038.meta\\n│   │   │   ├── 00000044.sst\\n│   │   │   ├── 00000045.sst\\n│   │   │   ├── 00000046.sst\\n│   │   │   ├── 00000047.sst\\n│   │   │   ├── 00000048.meta\\n│   │   │   ├── 00000049.meta\\n│   │   │   ├── 00000051.meta\\n│   │   │   ├── 00000052.meta\\n│   │   │   ├── 00000053.sst\\n│   │   │   ├── 00000054.meta\